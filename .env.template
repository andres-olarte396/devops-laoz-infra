# ═══════════════════════════════════════════════════════════════
# Dev Laoz Ecosystem — Variables de entorno
# Copiar como .env y completar antes de levantar el stack:
#   cp .env.template .env
# ═══════════════════════════════════════════════════════════════

# ── Seguridad ──────────────────────────────────────────────────
JWT_SECRET=

# ── Bases de datos ─────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/laoz

# ── URLs de servicios internos ─────────────────────────────────
# Usadas por @dev-laoz/core para auth middleware y secrets
SECRETS_API_URL=https://api-secrets:3501/api/secrets
AUTHORIZATION_API_URL=http://authorization-api:5000/api/authorization/validate

# ── Logging ────────────────────────────────────────────────────
INSIGHTS_HOST=api-insights
INSIGHTS_PORT=3600

# ── Comportamiento ─────────────────────────────────────────────
API_VERSION=1.0.0
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:80
